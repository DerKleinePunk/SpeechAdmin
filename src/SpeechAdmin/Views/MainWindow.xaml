<Window x:Class="SpeechAdmin.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SpeechAdmin.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:SpeechAdmin.ViewModels"
        Title="SpeechAdmin - Lokale Speech-to-Text"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:MainViewModel, IsDesignTimeCreatable=True}" >

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:RecordingStatusConverter x:Key="RecordingStatusConverter"/>
    </Window.Resources>

    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
        </StatusBar>
        <!--<ScrollViewer VerticalScrollBarVisibility="Auto"> -->
            <StackPanel Margin="20">
                <!-- Titel -->
                <TextBlock Text="🎤 Speech-to-Text Admin"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           Foreground="#333"/>

                <!-- Modell-Auswahl -->
                <TextBlock Text="Sprachmodell:"
                           FontWeight="Bold"
                           Margin="0,0,0,8"
                           Foreground="#555"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding AvailableModels}"
                              SelectedIndex="{Binding SelectedModelIndex}"
                              Padding="10,8"
                              Height="35">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Grid.Column="1"
                            Command="{Binding InstallModelCommand}"
                            Content="📥 Installieren"
                            Margin="10,0,0,0"
                            Padding="15,8"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="Bold"/>
                </Grid>

                <!-- Recording-Buttons -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center">
                    <Button Command="{Binding StartRecordingCommand}"
                            Content="🔴 Aufnahme starten"
                            Padding="20,15"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#2196F3"
                            Foreground="White"
                            Height="50"
                            Width="180"/>

                    <Button Command="{Binding StopRecordingCommand}"
                            Content="⏹️ Aufnahme stoppen"
                            Padding="20,15"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#FF5722"
                            Foreground="White"
                            Height="50"
                            Margin="10,0,0,0"
                            Width="180"/>
                </StackPanel>

                <!-- Status-Anzeige -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#FF9800"
                           FontSize="12"
                           Margin="0,0,0,10"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <!-- Transkription-Text -->
                <TextBlock Text="Textergebnis:"
                           FontWeight="Bold"
                           Margin="0,0,0,8"
                           Foreground="#555"/>
                <TextBox Text="{Binding TranscribedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="200"
                         Padding="15"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="White"
                         Foreground="#333"
                         BorderBrush="#DDD"
                         BorderThickness="1"
                         FontFamily="Segoe UI"
                         Margin="0,0,0,15"
                         AcceptsReturn="True"/>

                <!-- Text absenden -->
                <Button Command="{Binding SendToApplicationCommand}"
                        Content="✉️ Text zur aktiven App senden"
                        Padding="20,15"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#9C27B0"
                        Foreground="White"
                        Height="45"
                        Margin="0,0,0,20"/>

                <!-- Info-Bereich -->
                <Border BorderThickness="1" BorderBrush="#CCCCCC" Padding="15" Background="#FAFAFA" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="💡 Tipps:" FontWeight="Bold" Foreground="#333" Margin="0,0,0,8"/>
                        <TextBlock Text="• Drücke Ctrl+Alt+R um Aufnahme zu starten" Foreground="#666" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="• Stelle sicher das Zielfeld fokussiert ist (z.B. Email, Word)" Foreground="#666" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="• Dies ist eine Demo-Version" Foreground="#666" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        <!--</ScrollViewer>-->

        <!-- Loading-Indicator
        <Grid Background="#00000050"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Margin="30" MinWidth="250">
                <ProgressBar Height="5" IsIndeterminate="True" Foreground="#2196F3" Margin="10"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#333"
                           TextAlignment="Center"
                           Margin="10,15,10,10"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid> -->

    </DockPanel>
</Window>
